# Токен бота MAX (кабинет разработчика / карточка бота)
MAX_BOT_TOKEN=
# Числовой chat_id чата MAX, куда слать алерты (не Telegram ID)
MAX_ALERT_CHAT_ID=
# URL JSON API с температурой
TEMP_API_URL=http://192.168.4.252:9001/api/latest
# Порог температуры (°C) — алерт при превышении
TEMP_THRESHOLD=29.5
# Интервал опроса API (мс). По умолчанию 60000 (1 мин)
POLL_INTERVAL_MS=60000
# Путь к числу температуры в JSON. Ответ API — массив: 0.temperature
TEMP_JSON_PATH=0.temperature
# Файл состояния (чтобы после перезапуска не дублировать алерты)
# STATE_FILE=D:\path\to\bot-state.json
