# Токен бота от @BotFather
TELEGRAM_BOT_TOKEN=
# ID чата, куда слать алерты (можно узнать у @userinfobot)
TELEGRAM_CHAT_ID=
# URL JSON API с температурой
TEMP_API_URL=
# Порог температуры (°C) — алерт при превышении
TEMP_THRESHOLD=29.5
# Интервал опроса API (мс). По умолчанию 60000 (1 мин)
POLL_INTERVAL_MS=60000
# Путь к числу температуры в JSON. Ответ API — массив, берём первый датчик: 0.temperature
TEMP_JSON_PATH=0.temperature
# Файл состояния (чтобы после перезапуска не дублировать алерты). По умолчанию bot-state.json рядом с index.js
# STATE_FILE=D:\path\to\bot-state.json
